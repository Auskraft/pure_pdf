# Release signing for RuStore. Copy this file to `keystore.properties` (gitignored) and fill it in.
# NEVER commit keystore.properties or the .jks — back them up in your password manager.
#
# 1) Generate a keystore (keep the .jks OUTSIDE this repo, e.g. a secure folder). Run with the
#    Android Studio JBR if java isn't on PATH:
#      & "A:\AS\jbr\bin\keytool.exe" -genkeypair -v -storetype PKCS12 \
#          -keystore C:/keys/purepdf-release.jks -alias purepdf \
#          -keyalg RSA -keysize 2048 -validity 10000
#    (validity ~27 years; CN can be your name — Шварев Дмитрий Андреевич)
#
# 2) Point storeFile at it (forward slashes are fine on Windows) and set the passwords.

storeFile=C:/keys/purepdf-release.jks
storePassword=CHANGE_ME
keyAlias=purepdf
keyPassword=CHANGE_ME
